# Copy this file to .env and override any values for your environment.
# All fields are optional — defaults are production-safe as-is.

# Runtime environment identifier (development | staging | production)
ENVIRONMENT=development

# Python logging level (DEBUG | INFO | WARNING | ERROR | CRITICAL)
LOG_LEVEL=INFO

# HuggingFace model identifier used for tokenisation
MODEL_NAME=distilbert-base-uncased

# Path to the fine-tuned model artifact directory
# Relative paths are resolved from the project root; absolute paths also work.
ARTIFACTS_DIR=model/artifacts/final

# Maximum token sequence length — inputs beyond this are truncated
MAX_INPUT_LENGTH=256

# DataLoader batch size for training and evaluation
BATCH_SIZE=16

# Comma-separated list of valid API keys for /predict.
# Leave empty (or omit) to disable authentication — useful for local development.
# API_KEYS=your-secret-key-here

# Request rate limit for /predict (slowapi syntax: "N/period").
# RATE_LIMIT=60/minute
