            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false
          },
          "mappings": [],
          "unit": "reqps"
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "200"},
            "properties": [{"id": "color", "value": {"fixedColor": "green", "mode": "fixed"}}]
